---
layout: base.njk
pagination:
  data: collections.org
  size: 1
  alias: post
permalink: /weblog/{{ post.data.slug | stripLeadingSlash }}/
eleventyComputed:
  title: "{{ post.title }}"
---
<article class="post">
  <header class="post-header">
    <div class="post-title-row">
      <h1 class="post-title">{{ post.title }}</h1>
    </div>
    <p class="post-byline">Por {{ site.author.name }}</p>
    <time class="post-title-date" datetime="{{ post.date | isoDate }}">{{ post.date | isoDate }}</time>
    <div class="post-dateline" aria-hidden="true"></div>
  </header>

  <div class="post-body">
    {{ post.content | demoteHeadings | localizeFootnotes | fixFootnoteLinks | safe }}
  </div>

  {% if post.tags %}
  <ul class="post-tags">
    {% for tag in post.tags %}
    <li><a href="/weblog/etiquetas/{{ tag | slugify }}/">#{{ tag }}</a></li>
    {% endfor %}
  </ul>
  {% endif %}

  {% set arrowLeft %}<svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>{% endset %}
  {% set arrowUp %}<svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>{% endset %}
  {% set arrowRight %}<svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>{% endset %}
  <nav class="post-nav">
    {% if pagination.nextPageHref %}
      <a href="{{ pagination.nextPageHref }}" aria-label="Entrada anterior">{{ arrowLeft | safe }}</a>
    {% else %}
      <span class="post-nav-disabled">{{ arrowLeft | safe }}</span>
    {% endif %}
    <a href="/weblog/" aria-label="Subir">{{ arrowUp | safe }}</a>
    {% if pagination.previousPageHref %}
      <a href="{{ pagination.previousPageHref }}" aria-label="Entrada siguiente">{{ arrowRight | safe }}</a>
    {% else %}
      <span class="post-nav-disabled">{{ arrowRight | safe }}</span>
    {% endif %}
  </nav>
</article>
