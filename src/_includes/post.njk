---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-meta">
      <time datetime="{{ date | isoDate }}">{{ date | isoDate }}</time>
      {% if tags %}
      <ul class="post-tags">
        {% for tag in tags %}
        <li><a href="/weblog/etiquetas/{{ tag | slugify }}/">#{{ tag }}</a></li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>

  <nav class="post-nav">
    <a href="/weblog/">← todas las entradas</a>
  </nav>
</article>
