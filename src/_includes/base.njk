<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
  <link rel="alternate" type="application/atom+xml" href="/weblog/feed.xml" title="{{ site.title }}">
  <link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png">
  <link rel="preload" href="/assets/fonts/valkyrie/valkyrie-t3.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/triplicate/triplicate-t4.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/assets/style.css">
  <script defer src="https://umami.abrahamvillafigueroa.xyz/script.js" data-website-id="02d45e2e-b781-4ba6-86b0-387371072d6a"></script>
  <script>
    (function () {
      var theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body class="home-layout">

  <div class="home-grid">
    <aside class="home-sidebar">
      <nav class="sidebar-nav">
        <div class="sidebar-title">
          <span>Sitio web de</span>
          <span>Abraham Villa Figueroa</span>
        </div>
        <ul class="sidebar-links">
          <li><a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>principal</a></li>
          <li><a href="/publicaciones/" {% if page.url == "/publicaciones/" %}aria-current="page"{% endif %}>publicaciones</a></li>
          <li><a href="/weblog/" {% if page.url.startsWith("/weblog") %}aria-current="page"{% endif %}>weblog</a></li>
          <li><a href="/biblioteca/" {% if page.url == "/biblioteca/" %}aria-current="page"{% endif %}>biblioteca</a></li>
          <li><a href="/enlaces/" {% if page.url == "/enlaces/" %}aria-current="page"{% endif %}>enlaces</a></li>
        </ul>
        <div class="sidebar-icons">
          <a href="/weblog/etiquetas/" {% if page.url == "/weblog/etiquetas/" %}aria-current="page"{% endif %} aria-label="Etiquetas">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
          </a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar tema" onclick="
            var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
          ">
            <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </button>
          <a href="https://letterbird.co/a-v-f" aria-label="Contacto">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
          <a href="/weblog/feed.xml" aria-label="RSS">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
          </a>
        </div>
      </nav>
    </aside>

    <main class="home-main">
      {{ content | safe }}
    </main>
  </div>

  <script>
    (function () {
      if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

      var tooltip = document.createElement('div');
      tooltip.className = 'fn-tooltip';
      document.body.appendChild(tooltip);

      var activeRef = null;

      document.querySelectorAll('a.footref').forEach(function (ref) {
        var targetId = ref.getAttribute('href').replace('#', '');
        var def = document.getElementById(targetId);
        if (!def) return;
        var text = def.closest('.footnote-definition').querySelector('.footdef').textContent.trim();

        ref.addEventListener('mouseenter', function (e) {
          activeRef = ref;
          tooltip.textContent = text;
          tooltip.classList.add('fn-tooltip--visible');
          position(e);
        });
        ref.addEventListener('mousemove', function (e) {
          if (!tooltip.matches(':hover')) position(e);
        });
        ref.addEventListener('mouseleave', function () {
          setTimeout(function () {
            if (!tooltip.matches(':hover')) hide();
          }, 80);
        });
      });

      tooltip.addEventListener('mouseleave', hide);

      function hide() {
        tooltip.classList.remove('fn-tooltip--visible');
        activeRef = null;
      }

      function position(e) {
        var pad = 12;
        var tw = tooltip.offsetWidth;
        var th = tooltip.offsetHeight;
        var vw = window.innerWidth;
        var vh = window.innerHeight;
        var x = e.clientX + pad;
        var y = e.clientY - th - pad;
        if (x + tw > vw - pad) x = e.clientX - tw - pad;
        if (x < pad) x = pad;
        if (y < pad) y = e.clientY + pad;
        if (y + th > vh - pad) y = vh - th - pad;
        tooltip.style.left = x + 'px';
        tooltip.style.top  = y + 'px';
      }
    })();
  </script>
</body>
</html>
